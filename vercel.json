{
  "buildCommand": "npm run build -w client",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://localhost:5001/api/$1" },
    { "source": "/uploads/(.*)", "destination": "http://localhost:5001/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}